{
  "routes": [
    {
      "src": "/_vercel/(.*)",
      "has": [
        {
          "type": "host",
          "value": "dave.3dvr.tech"
        }
      ],
      "dest": "/_vercel/$1"
    },
    {
      "src": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "dave.3dvr.tech"
        }
      ],
      "dest": "/dave/$1"
    }
  ],
  "rewrites": [
    {
      "source": "/install",
      "destination": "/install.sh"
    }
  ],
  "headers": [
    {
      "source": "/install",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}

{
  "rewrites": [
    {
      "source": "/_vercel/:path*",
      "has": [
        {
          "type": "host",
          "value": "dave.3dvr.tech"
        }
      ],
      "destination": "/_vercel/:path*"
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "dave.3dvr.tech"
        }
      ],
      "destination": "/dave/:path*"
    },
    {
      "source": "/install",
      "destination": "/install.sh"
    }
  ],
  "headers": [
    {
      "source": "/install",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}

{
  "name": "3dvr-web",
  "private": true,
  "type": "module",
  "scripts": {
    "test:unit": "node --test tests/*.test.js",
    "test:e2e:local": "playwright test",
    "test:e2e:chromium:local": "playwright test --project=chromium-desktop --project=chromium-fold-closed",
    "test:e2e:webkit:local": "playwright test --project=webkit-desktop-safari --project=webkit-mobile-safari",
    "test:e2e": "sh ./scripts/playwright/run-in-linux.sh \"npm run test:e2e:local\"",
    "test:e2e:chromium": "sh ./scripts/playwright/run-in-linux.sh \"npm run test:e2e:chromium:local\"",
    "test:e2e:webkit": "sh ./scripts/playwright/run-in-linux.sh \"npm run test:e2e:webkit:local\"",
    "playwright:install:local": "playwright install chromium firefox webkit",
    "playwright:install": "sh ./scripts/playwright/run-in-linux.sh \"npm run playwright:install:local\""
  },
  "devDependencies": {
    "@playwright/test": "^1.54.0"
  }
}
